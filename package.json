{
  "name": "logseq-diagram-blocks",
  "version": "0.1.0",
  "description": "Mermaid diagrams in fenced code blocks: theme-synced, fullscreen pan/zoom, copy as PNG",
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite dev",
    "dev:harness": "vite dev --open /dev/index.html",
    "build": "vite build && node scripts/copy-vendors.mjs",
    "test": "vitest run",
    "screenshot": "node scripts/screenshot.mjs",
    "screenshot:logseq": "node scripts/screenshot-logseq.mjs"
  },
  "logseq": {
    "id": "logseq-diagram-blocks",
    "title": "Diagram Blocks",
    "icon": "./icon.png"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-regular": "^1.2.4",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@logseq/libs": "^0.0.17",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.2"
}
